# Google Apps Script Web App URL
NEXT_PUBLIC_APPS_SCRIPT_URL=your_apps_script_web_app_url_here

# Secret token (must match what's in your Apps Script)
APPS_SCRIPT_TOKEN=your_secret_token_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_string_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Allowed users (comma-separated emails)
ALLOWED_USERS=personal.amitabh@gmail.com

# Anthropic API Key (for enrichment)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
